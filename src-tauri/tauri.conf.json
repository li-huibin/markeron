{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "MarkerOnPlus",
  "version": "../package.json",
  "identifier": "com.markeronplus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:fe",
    "beforeBuildCommand": "npm run build:fe"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "MarkerOnPlus",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "MarkerOnPlus - 屏幕标注与截图工具",
      "menuOnLeftClick": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2Q0FBMzUzMkQyRDg0NTcKUldSWGhDMHRVNlBLUm1xZHVJSVp4cGkvVU0ybDZLT3RMOWxqVnQ4L25ON01hR2xwdndMOFFLYWkK",
      "endpoints": [
        "https://github.com/ifer47/markeron/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "./icons/installer-icon.ico",
        "sidebarImage": "./icons/installer-sidebar.bmp",
        "languages": ["SimpChinese", "English"]
      },
      "wix": {
        "language": "zh-CN",
        "bannerPath": "./icons/installer-banner-blank.bmp",
        "dialogImagePath": "./icons/installer-dialog.bmp"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1", "librsvg2-2"]
      }
    }
  }
}
